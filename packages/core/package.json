{
  "name": "fndeflate",
  "version": "0.1.0",
  "description": "Gzip, deflate, and zlib compression with TypeScript types. Uses native zlib on Node, Compression Streams in browsers.",
  "keywords": [
    "gzip",
    "deflate",
    "zlib",
    "compress",
    "decompress",
    "pako",
    "compression"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fndeflate"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/fndeflate/issues"
  },
  "homepage": "https://github.com/fnrhombus/fndeflate#readme",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "node": "./dist/node.js",
        "default": "./dist/browser.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "node": "./dist/node.cjs",
        "default": "./dist/browser.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
